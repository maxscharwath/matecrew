# Database
# Local: use Docker Compose values (see docker-compose.yml)
# Production: use Neon pooled + direct URLs
DATABASE_URL=postgresql://matecrew:matecrew@localhost:5432/matecrew
DIRECT_URL=postgresql://matecrew:matecrew@localhost:5432/matecrew

# Better Auth
BETTER_AUTH_SECRET=     # Generate with: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare R2 (invoice storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=matecrew-invoices
R2_PUBLIC_URL=

# Upstash QStash (session notifications cron)
# Get these from https://console.upstash.com/qstash
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Microsoft SSO (V2 — not needed yet)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=
