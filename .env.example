# Database
# Local: use Docker Compose values (see docker-compose.yml)
# Production: use Neon pooled + direct URLs
DATABASE_URL=postgresql://matecrew:matecrew@localhost:5432/matecrew
DIRECT_URL=postgresql://matecrew:matecrew@localhost:5432/matecrew

# Better Auth
BETTER_AUTH_SECRET=     # Generate with: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare R2 (invoice storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=matecrew-invoices
R2_PUBLIC_URL=

# Upstash QStash (session notifications cron)
# Get these from https://console.upstash.com/qstash
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Slack Bot (create app at api.slack.com/apps, add chat:write scope)
SLACK_BOT_TOKEN=
SLACK_BOT_USERNAME=MateCrew
SLACK_BOT_ICON_URL=

# Resend (password reset emails — get API key at resend.com, verify your domain)
RESEND_API_KEY=
EMAIL_FROM=MateCrew <noreply@yourdomain.com>

# Microsoft SSO — fill to enable the SSO button on login/signup
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
