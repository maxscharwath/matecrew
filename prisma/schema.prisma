generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum RequestStatus {
  REQUESTED
  SERVED
}

enum ConsumptionSource {
  DAILY_REQUEST
  MANUAL
}

enum StockMovementReason {
  SERVED
  UNSERVED
  ADJUSTMENT
  PURCHASE
}

enum PurchaseStatus {
  ORDERED
  DELIVERED
}

enum PaymentStatus {
  PENDING
  PAID
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Better Auth models ─────────────────────────────────

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  emailVerified   Boolean   @default(false)
  image           String?
  locale          String    @default("fr")
  slackUserId     String?   @unique
  defaultOfficeId String?
  defaultOffice   Office?   @relation("DefaultOffice", fields: [defaultOfficeId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]

  // App relations
  memberships        Membership[]
  joinRequests       JoinRequest[]
  dailyRequests      DailyRequest[]
  consumptionEntries ConsumptionEntry[]
  orderedBatches     PurchaseBatch[]    @relation("OrderedBy")
  paidBatches        PurchaseBatch[]    @relation("PaidBy")
  reimbursementsFrom ReimbursementLine[] @relation("ReimbursementFrom")
  reimbursementsTo   ReimbursementLine[] @relation("ReimbursementTo")
  stockMovements     StockMovement[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

// ─── App models ─────────────────────────────────────────

model Office {
  id                String  @id @default(cuid())
  name              String  @unique
  timezone          String  @default("Europe/Zurich")
  locale            String  @default("fr")
  slackChannelId    String?
  slackChannelLabel String?
  lowStockThreshold Int     @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships          Membership[]
  joinRequests         JoinRequest[]
  defaultForUsers      User[]               @relation("DefaultOffice")
  dailyRequests        DailyRequest[]
  stock                Stock?
  purchaseBatches      PurchaseBatch[]
  consumptionEntries   ConsumptionEntry[]
  reimbursementPeriods ReimbursementPeriod[]
  mateSessions         MateSession[]
}

model Membership {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  officeId String
  office   Office   @relation(fields: [officeId], references: [id], onDelete: Cascade)
  roles    Role[]   @default([USER])
  createdAt DateTime @default(now())

  @@unique([userId, officeId])
}

model JoinRequest {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  officeId  String
  office    Office            @relation(fields: [officeId], references: [id], onDelete: Cascade)
  status    JoinRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())

  @@unique([userId, officeId])
}

model MateSession {
  id                String    @id @default(cuid())
  officeId          String
  office            Office    @relation(fields: [officeId], references: [id], onDelete: Cascade)
  dayOfWeek         Int       // 0=Sun, 1=Mon ... 6=Sat
  startTime         String    // HH:mm — session opens & notification sent
  cutoffTime        String    // HH:mm — requests close
  label             String?   // e.g. "Matin", "Après-midi"
  lastNotifiedDate      DateTime? @db.Date // idempotency: skip if already notified today
  lastNotifiedMessageTs String?   // Slack message ts, used to chat.update the live message when requests change
  lastNotifiedChannelId String?

  createdAt DateTime @default(now())

  dailyRequests DailyRequest[]

  @@unique([officeId, dayOfWeek, startTime])
  @@index([dayOfWeek])
}

model DailyRequest {
  id            String        @id @default(cuid())
  date          DateTime      @db.Date
  officeId      String
  office        Office        @relation(fields: [officeId], references: [id], onDelete: Cascade)
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  mateSessionId String?
  mateSession   MateSession?  @relation(fields: [mateSessionId], references: [id], onDelete: SetNull)
  status        RequestStatus @default(REQUESTED)
  createdAt     DateTime      @default(now())

  @@unique([date, officeId, userId, mateSessionId])
}

model Stock {
  officeId            String    @id
  office              Office    @relation(fields: [officeId], references: [id], onDelete: Cascade)
  currentQty          Int       @default(0)
  updatedAt           DateTime  @updatedAt
  lowStockAlertSentAt DateTime?

  movements StockMovement[]
}

model StockMovement {
  id        String               @id @default(cuid())
  officeId  String
  stock     Stock                @relation(fields: [officeId], references: [officeId], onDelete: Cascade)
  delta     Int                  // +N or -N
  reason    StockMovementReason
  note      String?
  userId    String?
  user      User?                @relation(fields: [userId], references: [id])
  createdAt DateTime             @default(now())
}

model PurchaseBatch {
  id             String         @id @default(cuid())
  officeId       String
  office         Office         @relation(fields: [officeId], references: [id], onDelete: Cascade)
  status         PurchaseStatus @default(ORDERED)
  purchasedAt    DateTime       @default(now())
  deliveredAt    DateTime?
  orderedByUserId String
  orderedBy      User           @relation("OrderedBy", fields: [orderedByUserId], references: [id])
  paidByUserId   String
  paidBy         User           @relation("PaidBy", fields: [paidByUserId], references: [id])
  qty            Int
  unitPrice      Decimal        @db.Decimal(10, 2)
  totalPrice     Decimal        @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime       @default(now())

  invoices           InvoiceFile[]
  consumptionEntries ConsumptionEntry[]
}

model InvoiceFile {
  id              String        @id @default(cuid())
  purchaseBatchId String
  purchaseBatch   PurchaseBatch @relation(fields: [purchaseBatchId], references: [id], onDelete: Cascade)
  storageKey      String
  filename        String
  mimeType        String
  uploadedAt      DateTime      @default(now())
}

model ConsumptionEntry {
  id              String            @id @default(cuid())
  officeId        String
  office          Office            @relation(fields: [officeId], references: [id], onDelete: Cascade)
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  date            DateTime          @db.Date
  qty             Int               @default(1)
  source          ConsumptionSource @default(DAILY_REQUEST)
  purchaseBatchId String?
  purchaseBatch   PurchaseBatch?    @relation(fields: [purchaseBatchId], references: [id])
  cancelledAt     DateTime?
  createdAt       DateTime          @default(now())
}

model ReimbursementPeriod {
  id        String    @id @default(cuid())
  officeId  String
  office    Office    @relation(fields: [officeId], references: [id], onDelete: Cascade)
  month     Int       // 1-12
  year      Int       // e.g. 2026
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date
  createdAt DateTime  @default(now())

  lines ReimbursementLine[]

  @@unique([officeId, year, month])
}

model ReimbursementLine {
  id         String              @id @default(cuid())
  periodId   String
  period     ReimbursementPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  fromUserId String
  fromUser   User                @relation("ReimbursementFrom", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User                @relation("ReimbursementTo", fields: [toUserId], references: [id])
  amount     Decimal             @db.Decimal(10, 2)
  currency   String              @default("CHF")
  status     PaymentStatus       @default(PENDING)
  paidAt     DateTime?
}
